{
  "framework": "nextjs",
  "buildCommand": "prisma generate && next build",
  "functions": {
    "app/api/protected/gen-wallpaper/route.ts": {
      "maxDuration": 60
    },
    "app/api/protected/optimize-prompt/route.ts": {
      "maxDuration": 30
    },
    "app/api/upload/route.ts": {
      "maxDuration": 30
    },
    "app/api/worker/process-queue/route.ts": {
      "maxDuration": 60
    }
  },
  "crons": [
    {
      "path": "/api/worker/process-queue",
      "schedule": "* * * * *"
    }
  ]
}